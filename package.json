{
  "name": "zettelkastener",
  "version": "0.1.0",
  "description": "Zettelkasten専用エディター",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:setup": "npx electron-rebuild -f -w better-sqlite3 && electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --build --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "posttest": "npm run rebuild:electron",
    "test:ci": "npm run rebuild:node && vitest run",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "npx electron-rebuild -f -w better-sqlite3",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.4",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.4",
    "jsdom": "^24.1.1",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
